  "description": "SCF Bus Tracking Full-Stack App",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "git:save": "git add . && git diff --staged --quiet || git commit -m \"Auto update $(date)\" || true",
    "watch:git": "npx nodemon --watch . --ext js,jsx,ts,css,json,md,html --ignore '**/node_modules/**' --ignore '.git' --ignore '**/dist/**' --exec \"npm run git:save\""
  },
